NODE_ENV=development
PORT=5001
APP_DOMAIN=www.synap-ratings.com
CORS_ORIGINS=http://localhost:5000,https://www.synap-ratings.com

# Airtable
AIRTABLE_TOKEN=your_airtable_token_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_NAME=Leads

# reCAPTCHA Enterprise (Google Cloud)
RECAPTCHA_SITE_KEY=your_public_recaptcha_key
RECAPTCHA_ENTERPRISE_API_KEY=your_google_cloud_api_key
RECAPTCHA_ENTERPRISE_PROJECT_ID=your_google_cloud_project_id
RECAPTCHA_EXPECTED_ACTION=submit_lead
RECAPTCHA_MIN_SCORE=0.5

# Docker / Traefik (production)
TRAEFIK_NETWORK=n8n-https_default
TRAEFIK_CERTRESOLVER=letsencrypt
VITE_RECAPTCHA_SITE_KEY=your_public_recaptcha_key
VITE_RECAPTCHA_ACTION=submit_lead